# ============================================================
# Chameleon Honeypot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to git! Add to .gitignore:
#   echo ".env" >> .gitignore
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=chameleon
POSTGRES_PASSWORD=chameleon123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chameleon_db

# ── LLM API (DeepSeek) ─────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
LLM_PROVIDER=deepseek

# ── Ethereum Sepolia Blockchain ─────────────────────────────
# 1. Get a free RPC endpoint:
#    • Infura:  https://infura.io  → Create project → Copy Sepolia URL
#    • Alchemy: https://alchemy.com → Create app → Copy Sepolia URL
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# 2. Your wallet private key (MetaMask → Account Details → Export):
#    ⚠️  Use a TESTNET-ONLY wallet! Never use your mainnet key!
#    Get free Sepolia ETH: https://sepoliafaucet.com
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# 3. Deploy ChameleonLedger.sol to Sepolia:
#    • Use Remix IDE (https://remix.ethereum.org)
#    • Connect MetaMask (Sepolia network)
#    • Deploy → copy the contract address
CONTRACT_ADDRESS=0xDEPLOYED_CONTRACT_ADDRESS

# ── JWT Auth ────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-change-in-production-2024

# ── Gemini API (Chatbot) ───────────────────────────────────
GEMINI_API_KEY=your-gemini-key-here