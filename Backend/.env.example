# Chameleon Honeypot - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# Last Updated: 2026-02-16

# ============================================================
# PostgreSQL Database Configuration
# ============================================================
POSTGRES_USER=chameleon
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chameleon_db

# Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
ECHO_SQL=false

# ============================================================
# LLM API Configuration (Primary Deception Engine)
# ============================================================
# Provider: "deepseek" or "glm5"
LLM_PROVIDER=deepseek

# DeepSeek API (OpenAI-compatible, recommended)
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# GLM-5 API (Alternative)
# Get your API key from: https://open.bigmodel.cn/
GLM5_API_KEY=your_glm5_api_key_here
GLM5_API_URL=https://open.bigmodel.cn/api/paas/v3/model-api/chatglm_turbo/invoke
GLM5_MODEL=chatglm_turbo

# LLM Behavior Settings
LLM_MAX_TOKENS=100
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30

# Feature Flags
USE_LLM_DECEPTION=true
USE_MERKLE_INTEGRITY=true

# ============================================================
# Gemini API Configuration (Fallback/Alternative)
# ============================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Legacy MongoDB Configuration (for migration reference)
# ============================================================
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net

# ============================================================
# Application Configuration
# ============================================================
JWT_SECRET_KEY=your_jwt_secret_key_change_in_production
GEOIP_API_URL=http://ip-api.com/json/
PORT=8000

# Tarpit Settings
TARPIT_THRESHOLD=5
TARPIT_DELAY_MIN=2.0
TARPIT_DELAY_MAX=10.0

# Classification Settings
CONFIDENCE_THRESHOLD=0.7
MAX_INPUT_LENGTH=200