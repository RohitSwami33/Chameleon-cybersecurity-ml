/* Chameleon Forensics — Global Design Tokens */

:root {
  /* Background colors */
  --bg-default: #050810;
  --bg-paper: #0a0f1e;
  --bg-elevated: #0f1628;

  /* Accent colors */
  --primary: #00d4ff;
  --secondary: #ff3d71;
  --success: #00e676;
  --warning: #ffab00;
  --info: #7c4dff;

  /* Text colors */
  --text-primary: #e8f4fd;
  --text-secondary: #7a9bbf;
  --text-muted: #3d5a7a;

  /* Attack type colors */
  --color-benign: #00e676;
  --color-sqli: #ff3d71;
  --color-ssi: #ff6584;
  --color-xss: #ffab00;

  /* Borders & Elevation */
  --border-subtle: rgba(0, 212, 255, 0.08);
  --border-hover: rgba(0, 212, 255, 0.25);
  --glow-cyan: rgba(0, 212, 255, 0.12);
  --glow-red: rgba(255, 61, 113, 0.2);

  /* Spacing */
  --space-unit: 8px;
  --radius-card: 12px;
  --radius-hero: 20px;
  --card-padding: 20px;
  --grid-gap: 16px;

  /* Fonts */
  --font-display: 'Orbitron', 'Rajdhani', sans-serif;
  --font-body: 'IBM Plex Mono', monospace;
  --font-ui: 'DM Sans', 'Space Mono', sans-serif;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html,
body,
#root {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
}

body {
  margin: 0;
  padding: 0;
  width: 100vw;
  font-family: var(--font-ui);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background-color: var(--bg-default);
  color: var(--text-primary);
  overflow-x: hidden;
}

code {
  font-family: var(--font-body);
}

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: var(--bg-default);
}

::-webkit-scrollbar-thumb {
  background: rgba(0, 212, 255, 0.15);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 212, 255, 0.3);
}

a {
  color: var(--primary);
  text-decoration: none;
  transition: color 0.3s ease;
}

a:hover {
  color: var(--warning);
}

/* Pulse animation */
@keyframes pulse {

  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }

  50% {
    transform: scale(1.5);
    opacity: 0;
  }
}

@keyframes pulse-soft {

  0%,
  100% {
    transform: scale(1);
    opacity: 0.8;
  }

  50% {
    transform: scale(1.15);
    opacity: 1;
  }
}

@keyframes glow-pulse {

  0%,
  100% {
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.3);
  }

  50% {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
  }
}

/* Live dot animation */
@keyframes live-dot {

  0%,
  100% {
    background-color: #00e676;
    box-shadow: 0 0 6px #00e676;
  }

  50% {
    background-color: #ff3d71;
    box-shadow: 0 0 12px #ff3d71;
  }
}

/* Typing indicator dots */
@keyframes typing-dot {

  0%,
  80%,
  100% {
    transform: scale(0);
    opacity: 0.4;
  }

  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* Toast Notification Styling Override */
.Toastify__toast-container {
  z-index: 9999;
}

.Toastify__toast--dark {
  background-color: var(--bg-paper) !important;
  color: var(--text-primary) !important;
  border: 1px solid var(--border-subtle);
  backdrop-filter: blur(12px);
}

/* ── DepthLayers fog blob keyframes ─────────────────────────────────────── */
@keyframes drift1 {
  from {
    transform: translate(0, 0) scale(1);
  }

  to {
    transform: translate(40px, -20px) scale(1.1);
  }
}

@keyframes drift2 {
  from {
    transform: translate(0, 0);
  }

  to {
    transform: translate(-60px, 30px);
  }
}

@keyframes drift3 {
  from {
    transform: translate(0, 0);
  }

  to {
    transform: translate(30px, -50px) scale(0.9);
  }
}

/* ── GlobalBackground (TRON Grid, Particles, Vignette) ────────────────── */
.grid-floor {
  position: absolute;
  inset: -20% -20% -20% -20%;
  pointer-events: none;
  background:
    linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  background-position: center center;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 100%, black 0%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 100%, black 0%, transparent 100%);
  transform: perspective(600px) rotateX(45deg);
  transform-origin: 50% 100%;
  animation: gridScroll 8s linear infinite;
  will-change: transform;
}

@keyframes gridScroll {
  from {
    background-position: 0 0;
  }

  to {
    background-position: 0 40px;
  }
}

.vignette {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(ellipse at center, transparent 40%, rgba(5, 8, 16, 0.85) 100%);
}

.ambient-particle {
  position: absolute;
  width: 2px;
  height: 2px;
  background-color: #00d4ff;
  border-radius: 50%;
  box-shadow: 0 0 4px #00d4ff;
  animation-name: float;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  animation-direction: alternate;
  will-change: transform;
}

@keyframes float {
  from {
    transform: translateY(0px) translateX(0px);
  }

  to {
    transform: translateY(-40px) translateX(20px);
  }
}

/* ── Holographic Stat Numbers (Scanline & Pulse) ──────────────────────── */
.stat-number-container {
  position: relative;
  overflow: hidden;
  display: inline-block;
}

.stat-number-container::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(0deg,
      transparent,
      transparent 2px,
      rgba(0, 212, 255, 0.015) 2px,
      rgba(0, 212, 255, 0.015) 4px);
  pointer-events: none;
  animation: scanMove 8s linear infinite;
}

@keyframes scanMove {
  from {
    background-position: 0 0;
  }

  to {
    background-position: 0 100px;
  }
}

@keyframes glowPulse {

  0%,
  92.5%,
  100% {
    opacity: 0.85;
    text-shadow: 0 0 10px currentColor;
  }

  96.25% {
    opacity: 1;
    text-shadow: 0 0 20px currentColor, 0 0 40px currentColor;
  }
}